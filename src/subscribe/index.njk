<script src="https://js.stripe.com/v3/"></script>
<script>
(function() {
  const stripe = Stripe('pk_live_51S9DtzC5seLx7yR7Uw5rcWNZsOxKGElPKqEJeChd3dng6t8bYN99RTbFXFxjgSdGVo1ulp9VWTiitIGyrwqB8M0V00ZigwNIK1');
  const elements = stripe.elements();
  const cardElement = elements.create('card', {
    style: {
      base: { fontSize: '16px', color: '#1a1a1a', '::placeholder': { color: '#aaa' } },
      invalid: { color: '#e53e3e' },
    }
  });
  cardElement.mount('#card-element');

  const skipCheckbox = document.getElementById('skip-card');
  const cardWrapper = document.getElementById('card-element');

  skipCheckbox.addEventListener('change', () => {
    cardWrapper.style.opacity = skipCheckbox.checked ? '0.35' : '1';
    cardWrapper.style.pointerEvents = skipCheckbox.checked ? 'none' : 'auto';
    document.getElementById('card-error').textContent = '';
  });
  // Start with card hidden (skip checked by default)
  cardWrapper.style.opacity = '0.35';
  cardWrapper.style.pointerEvents = 'none';

  document.getElementById('subscribe-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submit-btn');
    const errorEl = document.getElementById('card-error');
    const warningEl = document.getElementById('topic-warning');

    const email = document.getElementById('email').value.trim();
    const topics = [...document.querySelectorAll('input[name="topics"]:checked')].map(cb => parseInt(cb.value));

    if (topics.length === 0) {
      warningEl.style.display = 'block';
      warningEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }
    warningEl.style.display = 'none';

    btn.disabled = true;
    btn.textContent = 'Subscribing…';
    errorEl.textContent = '';

    let paymentMethodId = null;

    // If card entry is active (skip unchecked), capture it
    if (!skipCheckbox.checked) {
      try {
        // Create SetupIntent server-side
        const siRes = await fetch('/api/setup-intent', { method: 'POST' });
        if (!siRes.ok) throw new Error('Could not initialise card capture.');
        const { client_secret } = await siRes.json();

        const { setupIntent, error } = await stripe.confirmCardSetup(client_secret, {
          payment_method: { card: cardElement },
        });

        if (error) {
          errorEl.textContent = error.message;
          btn.disabled = false;
          btn.textContent = 'Start receiving briefings →';
          return;
        }
        paymentMethodId = setupIntent.payment_method;
      } catch (err) {
        errorEl.textContent = err.message;
        btn.disabled = false;
        btn.textContent = 'Start receiving briefings →';
        return;
      }
    }

    // POST to subscribe
    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, topics, payment_method_id: paymentMethodId }),
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(data.error || `Server error ${res.status}`);
      }

      window.location.href = '/success/';
    } catch (err) {
      errorEl.textContent = err.message;
      btn.disabled = false;
      btn.textContent = 'Start receiving briefings →';
    }
  });
})();
</script>

