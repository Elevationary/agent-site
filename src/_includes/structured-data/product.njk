{% if product %}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": "https://agent.elevationary.com/{{ product.slug }}/#service",
    "name": "{{ product.title }}",
    "description": "{{ product.description | escape }}",
    "serviceType": "{% if product.type == 'subscription' %}AI Intelligence Subscription{% else %}AI Strategy Consulting{% endif %}",
    "provider": {
      "@type": "Organization",
      "@id": "{{ site.orgId }}",
      "name": "{{ site.name }}",
      "url": "{{ site.url }}"
    },
    "areaServed": "Worldwide",
    "url": "https://agent.elevationary.com/{{ product.slug }}/",
    "image": [
      "https://agent.elevationary.com{{ product.og_image }}"
    ],
    "offers": {
      "@type": "Offer",
      "@id": "https://agent.elevationary.com/{{ product.slug }}/#offer",
      "url": "https://agent.elevationary.com/{{ product.slug }}/",
      "priceCurrency": "{{ product.currency }}",
      "price": "{{ product.price }}",
      "availability": "https://schema.org/InStock",
      "seller": {
        "@type": "Organization",
        "name": "Elevationary",
        "url": "https://elevationary.com"
      }
    }
  }
</script>
{% endif %}
