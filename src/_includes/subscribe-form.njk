<form action="/api/subscribe" method="POST" class="subscribe-form">
  <label for="email" class="subscribe-form__label">Email address</label>
  <div class="subscribe-form__row">
    <input
      type="email"
      id="email"
      name="email"
      required
      placeholder="you@example.com"
      class="subscribe-form__input"
    />
    <button type="submit" class="button primary subscribe-form__btn">Subscribe Free</button>
  </div>
</form>

