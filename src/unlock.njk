<script>
(function () {
  let billing = 'monthly';

  const toggleBtns = document.querySelectorAll('.toggle-btn');
  const priceAmounts = document.querySelectorAll('.price-amount');
  const annualNotes = document.querySelectorAll('.price-annual-note');
  const checkoutBtns = document.querySelectorAll('.checkout-button');

  function setBilling(mode) {
    billing = mode;
    toggleBtns.forEach(b => b.classList.toggle('toggle-btn--active', b.dataset.billing === mode));
    priceAmounts.forEach(el => {
      el.textContent = mode === 'annual' ? el.dataset.annual : el.dataset.monthly;
    });
    annualNotes.forEach(el => {
      el.style.display = mode === 'annual' ? 'block' : 'none';
    });
  }

  toggleBtns.forEach(b => b.addEventListener('click', () => setBilling(b.dataset.billing)));

  checkoutBtns.forEach(btn => {
    btn.addEventListener('click', async () => {
      const plan = billing === 'annual' ? btn.dataset.annualPlan : btn.dataset.monthlyPlan;
      const original = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Redirecting…';

      try {
        const res = await fetch('/api/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ plan }),
        });
        const data = await res.json();
        if (data.url) {
          window.location.href = data.url;
        } else {
          alert('Checkout failed: ' + (data.error || 'Unknown error'));
          btn.disabled = false;
          btn.textContent = original;
        }
      } catch (err) {
        alert('Network error. Please try again.');
        btn.disabled = false;
        btn.textContent = original;
      }
    });
  });
})();
</script>

